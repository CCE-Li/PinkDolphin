APP_NAME=Phishing Mail Backend
APP_ENV=local
API_V1_PREFIX=/api
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:80,http://127.0.0.1:80
ADMIN_BEARER_TOKEN=change-me

DATABASE_URL=postgresql+psycopg://your_user:your_password@your_host:5432/your_database
REDIS_URL=redis://your_host:6379/0
CELERY_BROKER_URL=redis://your_host:6379/1
CELERY_RESULT_BACKEND=redis://your_host:6379/2
CELERY_DEFAULT_QUEUE=default
MAILBOX_ANALYSIS_QUEUE=mailbox_analysis
MAILBOX_ANALYSIS_RATE_LIMIT=1/m

MAX_UPLOAD_SIZE_MB=10
LOG_LEVEL=INFO
AUTO_MIGRATE_ON_STARTUP=true

AUTO_INGEST_ENABLED=true
AUTO_INGEST_POLL_SECONDS=15
LOCAL_INBOX_DIR=sample_data/inbox
LOCAL_PROCESSED_DIR=sample_data/processed
LOCAL_FAILED_DIR=sample_data/failed

PRIVACY_SKIP_URL_ON_SENDER_ALLOWLIST=false
PRIVACY_SKIP_ATTACHMENT_ON_SENDER_ALLOWLIST=false
PRIVACY_SKIP_LLM_ON_SENDER_ALLOWLIST=false

URL_SCAN_PROVIDER=mock
SAFEBROWSING_API_KEY=
SAFEBROWSING_TIMEOUT_SECONDS=10

ATTACHMENT_SCAN_PROVIDER=mock
VIRUSTOTAL_API_KEY=
VIRUSTOTAL_TIMEOUT_SECONDS=30
VIRUSTOTAL_POLL_ATTEMPTS=4
VIRUSTOTAL_POLL_INTERVAL_SECONDS=4
VIRUSTOTAL_UPLOAD_ENABLED=false

LLM_ANALYZER_ENABLED=false
LLM_PROVIDER_MODE=mock
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=your_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=8
LLM_MAX_INPUT_CHARS=6000
LLM_TEMPERATURE=0

ANALYZER_WEIGHTS={"header_auth":1.0,"content_rule":1.2,"url":1.3,"attachment":1.1,"behavior":0.9,"llm":0.8}
ENABLED_ANALYZERS=["header_auth","content_rule","url","attachment","behavior","llm"]
